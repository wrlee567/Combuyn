# Copy to .env for local non-docker runs.
DATABASE_URL=postgresql+psycopg://combuyn:combuyn@localhost:5432/combuyn
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
SEED_ON_STARTUP=true
# Local dev: also seed illustrative sample vendors / AI systems. Keep false in prod.
SEED_DEMO_DATA=true
ENVIRONMENT=development
# JWT bearer auth signing secret. Override with a strong random value in prod.
JWT_SECRET=dev-insecure-secret-change-me
# Enables POST /auth/demo-token for portfolio demos. Keep false unless needed.
ENABLE_DEMO_AUTH=false
